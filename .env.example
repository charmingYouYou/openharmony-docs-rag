# API 服务监听地址；容器内保持 0.0.0.0
API_HOST=0.0.0.0
# API 服务监听端口；默认对外暴露这个端口
API_PORT=8000

# Qdrant 主机名；Docker Compose 内使用 qdrant，本地运行使用 localhost
QDRANT_HOST=localhost
# Qdrant HTTP 端口
QDRANT_PORT=6333

# 对话模型 API Key
LLM_API_KEY=sk-xxx
# 对话模型 OpenAI 兼容 Base URL
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 对话模型名称
LLM_CHAT_MODEL=kimi-k2.5

# 向量模型 API Key
EMBEDDING_API_KEY=sk-xxx
# 向量模型 Base URL
EMBEDDING_BASE_URL=https://api.siliconflow.cn
# 向量模型名称
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
# 可选：Qwen 检索 query instruction；留空表示不加前缀
EMBEDDING_QUERY_PREFIX=Instruct: Given a question about OpenHarmony development documentation, retrieve relevant passages that answer the question\nQuery: 

# 是否启用二阶段 rerank；设为 false 时只做向量召回
RERANK_ENABLED=true
# Rerank 模型名称；默认复用 EMBEDDING_API_KEY 和 EMBEDDING_BASE_URL
RERANK_MODEL=Qwen/Qwen3-Reranker-4B

# OpenHarmony 文档本地缓存目录
DOCS_LOCAL_PATH=./data/raw/openharmony-docs

# 可选：SQLite 元数据文件路径
# SQLITE_DB_PATH=./storage/metadata.db
# 可选：Qdrant collection 名称
# QDRANT_COLLECTION=openharmony-docs-zh-cn
# 可选：文档仓库地址
# DOCS_REPO_URL=https://gitee.com/openharmony/docs.git
# 可选：文档仓库分支
# DOCS_BRANCH=master
# 可选：仅索引这些目录
# DOCS_INCLUDE_DIRS=zh-cn/application-dev,zh-cn/design
# 可选：默认检索返回数量
# RETRIEVAL_TOP_K=8
# 可选：Rerank 候选重排数量
# RERANK_TOP_K=15
# 可选：当 rerank 与 embedding 不同供应商时单独设置 API Key
# RERANK_API_KEY=sk-xxx
# 可选：当 rerank 与 embedding 不同供应商时单独设置 Base URL
# RERANK_BASE_URL=https://api.siliconflow.cn
# 可选：单次 embedding 请求 batch 大小
# EMBEDDING_BATCH_SIZE=512
# 可选：embedding 429 重试次数
# EMBEDDING_MAX_RETRIES=5
# 可选：embedding 429 重试退避秒数
# EMBEDDING_RETRY_BACKOFF_SECONDS=2
# 可选：embedding 批次间固定延迟秒数
# EMBEDDING_INTER_BATCH_DELAY_SECONDS=0
# 可选：document input_type；默认是 document
# EMBEDDING_DOCUMENT_INPUT_TYPE=document
# 可选：query input_type；默认是 query
# EMBEDDING_QUERY_INPUT_TYPE=query
# 可选：document 前缀；默认留空
# EMBEDDING_DOCUMENT_PREFIX=
# 可选：chunk 目标大小
# CHUNK_TARGET_SIZE=600
# 可选：chunk overlap
# CHUNK_OVERLAP=100
# 可选：rerank 429 重试次数
# RERANK_MAX_RETRIES=5
# 可选：rerank 429 重试退避秒数
# RERANK_RETRY_BACKOFF_SECONDS=2
