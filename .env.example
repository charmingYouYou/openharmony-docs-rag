# API 配置
API_HOST=0.0.0.0
API_PORT=8000

# Qdrant 配置
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=openharmony-docs-zh-cn

# SQLite 配置
SQLITE_DB_PATH=./storage/metadata.db

# OpenAI 配置
OPENAI_API_KEY=sk-xxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# 文档仓库配置
DOCS_REPO_URL=https://gitee.com/openharmony/docs.git
DOCS_BRANCH=master
DOCS_LOCAL_PATH=./data/raw/openharmony-docs
DOCS_INCLUDE_DIRS=zh-cn/application-dev,zh-cn/design

# Chunking 配置
CHUNK_TARGET_SIZE=600
CHUNK_OVERLAP=100

# Retrieval 配置
RETRIEVAL_TOP_K=8
RERANK_TOP_K=15
HYBRID_ALPHA=0.5
