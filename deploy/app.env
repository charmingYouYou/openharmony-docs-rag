# Docker 部署默认运行时配置；Web 控制台和 Compose 都会读写这份文件。
API_HOST=0.0.0.0
API_PORT=8000

# Docker Compose 内固定连到 qdrant 服务。
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# 对话模型配置
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_CHAT_MODEL=kimi-k2.5

# 向量模型配置
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_QUERY_PREFIX=Instruct: Given a question about OpenHarmony development documentation, retrieve relevant passages that answer the question\nQuery: 

# 二阶段重排
RERANK_ENABLED=true
RERANK_MODEL=Qwen/Qwen3-Reranker-4B

# 文档缓存与元数据
DOCS_LOCAL_PATH=./data/raw/openharmony-docs
# SQLITE_DB_PATH=./storage/metadata.db
# QDRANT_COLLECTION=openharmony-docs-zh-cn
# DOCS_REPO_URL=https://gitee.com/openharmony/docs.git
# DOCS_BRANCH=master
# DOCS_INCLUDE_DIRS=zh-cn/application-dev,zh-cn/design

# 可选高级参数
# RETRIEVAL_TOP_K=8
# RERANK_TOP_K=15
# RERANK_API_KEY=sk-xxx
# RERANK_BASE_URL=https://api.siliconflow.cn
# EMBEDDING_BATCH_SIZE=512
# EMBEDDING_MAX_RETRIES=5
# EMBEDDING_RETRY_BACKOFF_SECONDS=2
# EMBEDDING_INTER_BATCH_DELAY_SECONDS=0
# EMBEDDING_DOCUMENT_INPUT_TYPE=document
# EMBEDDING_QUERY_INPUT_TYPE=query
# EMBEDDING_DOCUMENT_PREFIX=
# CHUNK_TARGET_SIZE=600
# CHUNK_OVERLAP=100
# RERANK_MAX_RETRIES=5
# RERANK_RETRY_BACKOFF_SECONDS=2
